# Copy to `.env` and fill in to run against a real model.
# Without these, the repo runs on the dependency-free MockLLM.

# Set to 1 to use the real OpenAI client instead of the MockLLM.
USE_OPENAI=

# Your OpenAI API key (required only when USE_OPENAI=1).
OPENAI_API_KEY=

# Optional model overrides (defaults shown).
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
